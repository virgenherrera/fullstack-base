{
  "name": "@base/quality-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "pretest:e2e": "pnpm --filter @base/web run build",
    "test:e2e": "playwright test",
    "test:dynamic": "pnpm run test:e2e",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "test:doctor": "pnpm run test:static && pnpm run test:types",
    "eslintCheck": "eslint .",
    "prettierCheck": "prettier --check 'src/**/*.ts'",
    "cleanup": "rimraf ../../artifacts/quality/web/"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@eslint/js": "catalog:",
    "@eslint/json": "catalog:",
    "@eslint/markdown": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "http-server": "14.1.1",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "zod": "catalog:"
  }
}
