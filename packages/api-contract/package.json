{
  "name": "@base/api-contract",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./health": "./src/health.ts"
  },
  "engines": {
    "node": ">=24.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "test:doctor": "pnpm run test:static && pnpm run test:types",
    "cleanup": "rimraf artifacts/api-contract/",
    "eslintCheck": "eslint .",
    "prettierCheck": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@eslint/json": "catalog:",
    "@eslint/markdown": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
