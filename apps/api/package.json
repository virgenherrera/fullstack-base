{
  "name": "@base/api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "start:dev": "nest start --watch",
    "start:prod": "node artifacts/dist/main",
    "build": "pnpm run build:api-docs && pnpm run build:app",
    "build:app": "nest build -p tsconfig.build.prod.json",
    "build:api-docs": "ts-node -r tsconfig-paths/register ./scripts/build-openapi-artifact.ts",
    "test:static": "pnpm run eslintCheck && pnpm run prettierCheck",
    "test:types": "tsc --noEmit",
    "test:unit": "jest --testPathPatterns='src/' --coverageThreshold='{}'",
    "test:e2e": "jest --testPathPatterns='test/' --coverageThreshold='{}'",
    "test:dynamic": "jest",
    "test:doctor": "pnpm run test:static && pnpm run test:types && pnpm run test:dynamic",
    "eslintCheck": "eslint .",
    "prettierCheck": "prettier --check '{scripts,src,test}/**/*.ts'",
    "cleanup": "rimraf artifacts/dist/ ../../artifacts/api-docs/ artifacts/coverage/"
  },
  "dependencies": {
    "@base/api-contract": "workspace:*",
    "@base/paths": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/serve-static": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@nestjs/terminus": "catalog:",
    "compression": "catalog:",
    "date-fns": "catalog:",
    "helmet": "catalog:",
    "nestjs-zod": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@eslint/json": "catalog:",
    "@eslint/markdown": "catalog:",
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/compression": "catalog:",
    "@types/express": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/supertest": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "jest": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "source-map-support": "catalog:",
    "supertest": "catalog:",
    "ts-jest": "catalog:",
    "ts-loader": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
